{{define "base"}}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{block "title" .}}Sayfa Bulunamadı{{end}} - DevRyanBlog</title>
    <link rel="stylesheet" href="/static/css/main.css">
</head>
<body>
    <!-- Arka planda gezen logo için container -->
    <div class="bg-animation-container">
        <img src="/static/img/logo.png" alt="" class="floating-logo" />
        <img src="/static/img/logo.png" alt="" class="floating-logo" />
        <img src="/static/img/logo.png" alt="" class="floating-logo" />
        <img src="/static/img/logo.png" alt="" class="floating-logo" />
        <img src="/static/img/logo.png" alt="" class="floating-logo" />
    </div>

    <header>
        <div class="brand">
            <h1>
                <a href="/">
                    <img src="/static/img/logo.png" alt="DevRyanBlog Logo" class="logo-img">
                    <span>DevRyanBlog</span>
                </a>
            </h1>
        </div>
        <nav>
            <a href="/">Ana Sayfa</a>
            <a href="/articles">Yazılarım</a>
            <a href="/admin" class="nav-admin">Admin</a>
            <a href="/admin/settings" class="nav-admin">Terminal Ayarları</a>
        </nav>
    </header>

    <main>
        {{block "main" .}}<p>İçerik yüklenirken bir sorun oluştu.</p>{{end}}
    </main>

    <footer>
        <p>&copy; 2026 Devryan. Tüm hakları saklıdır.</p>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.querySelector('.bg-animation-container');
            const logos = document.querySelectorAll('.floating-logo');

            if (!container || logos.length === 0) return;

            // Her bir logonun kendi pozisyonunu ve hızını tutacak bir liste (array) oluşturuyoruz
            const logoData = Array.from(logos).map(logo => {
                return {
                    el: logo,
                    x: Math.random() * (container.clientWidth - 200), // CSS'te boyut 200px
                    y: Math.random() * (container.clientHeight - 200),
                    dx: (Math.random() - 0.5) * 2, // Hız ayarı
                    dy: (Math.random() - 0.5) * 2
                };
            });

            function animate() {
                logoData.forEach(data => {
                    data.x += data.dx;
                    data.y += data.dy;

                    // Ekran sınırlarına çarpıp sekme (Logo boyutu 200px)
                    if (data.x + 200 > container.clientWidth || data.x < 0) { data.dx = -data.dx; }
                    if (data.y + 200 > container.clientHeight || data.y < 0) { data.dy = -data.dy; }

                    data.el.style.transform = `translate(${data.x}px, ${data.y}px)`;
                });
                requestAnimationFrame(animate);
            }

            animate();
        });
    </script>
</body>
</html>
{{end}}