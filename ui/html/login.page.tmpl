{{template "base" .}}
{{define "title"}}Sistem Girişi{{end}}
{{define "main"}}
<div class="admin-section" style="max-width: 450px; margin: 2rem auto; text-align:center;">
    <h2 style="color: var(--primary); margin-top:0;">DevryanBlog Admin</h2>
    <p style="color: var(--text-muted); margin-bottom: 2rem;">İçerik yönetimi için lütfen giriş yapın.</p>
    
    {{if .Error}}<div style="background: rgba(239, 68, 68, 0.1); border: 1px solid var(--danger); color: var(--danger); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">{{.Error}}</div>{{end}}
    
    <form action="/login" method="POST" style="text-align: left;">
        <div class="form-group">
            <label for="username">Kullanıcı Adı</label>
            <input type="text" id="username" name="username" placeholder="admin" required>
        </div>
        <div class="form-group">
            <label for="password">Yönetici Parolası</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn" style="width: 100%;">Giriş Yap</button>
    </form>
    <p style="margin-top: 2rem; font-size: 0.85rem;"><a href="/" style="color: var(--text-muted);">← Ana Sayfaya Dön</a></p>
</div>
{{end}}