{{define "base"}}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{block "title" .}}Sayfa Bulunamadı{{end}} - DevRyanBlog</title>
    <link rel="stylesheet" href="/static/css/main.css">
</head>
<body>
    <!-- Arka planda gezen logo için container -->
    <div class="bg-animation-container">
        <img src="/static/img/logo.png" alt="" class="floating-logo" />
    </div>

    <header>
        <div class="brand">
            <h1>
                <a href="/">
                    <img src="/static/img/logo.png" alt="DevRyanBlog Logo" class="logo-img">
                    <span>DevRyanBlog</span>
                </a>
            </h1>
        </div>
        <nav>
            <a href="/">Ana Sayfa</a>
            <a href="/admin" class="nav-admin">Admin</a>
        </nav>
    </header>

    <main>
        {{block "main" .}}<p>İçerik yüklenirken bir sorun oluştu.</p>{{end}}
    </main>

    <footer>
        <p>&copy; 2026 Devryan. Tüm hakları saklıdır.</p>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.querySelector('.bg-animation-container');
            const logo = document.querySelector('.floating-logo');

            if (!container || !logo) return;

            let x = Math.random() * (container.clientWidth - logo.clientWidth);
            let y = Math.random() * (container.clientHeight - logo.clientHeight);
            let dx = (Math.random() - 0.5) * 1.5; // Hız ayarı
            let dy = (Math.random() - 0.5) * 1.5;

            function animate() {
                x += dx;
                y += dy;

                // Ekran sınırlarına çarpıp sekme
                if (x + logo.clientWidth > container.clientWidth || x < 0) { dx = -dx; }
                if (y + logo.clientHeight > container.clientHeight || y < 0) { dy = -dy; }

                logo.style.transform = `translate(${x}px, ${y}px)`;
                requestAnimationFrame(animate);
            }

            animate();
        });
    </script>
</body>
</html>
{{end}}