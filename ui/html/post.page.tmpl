{{template "base" .}}
{{define "title"}}{{.Blog.Title}}{{end}}
{{define "main"}}
<article class="blog-card detail-card">
    <h2 class="section-title" style="border:none; margin-bottom: 0;">{{.Blog.Title}}</h2>
    <span class="blog-date" style="border-bottom: 1px solid var(--border); padding-bottom: 1rem; margin-bottom: 2rem;">>>> SYS.DATE: {{.Blog.CreatedAt.Format "02 Jan 2006 - 15:04"}}</span>
    
    <div class="post-content">
        {{.Blog.Content}}
    </div>
    
    <div class="comments-section">
        <h4>[ AĞ İZLERİ - KULLANICI YORUMLARI ]</h4>
        {{if .Blog.Comments}}
            <ul class="comment-list">
                {{range .Blog.Comments}}
                <li class="comment-item">
                    <span class="comment-date">[{{.CreatedAt.Format "02.01.06 15:04"}}]</span>
                    <span class="comment-text">{{.Content}}</span>
                </li>
                {{end}}
            </ul>
        {{else}}
            <p class="no-comments">Ağda henüz veri yok. İlk veri paketini sen yolla.</p>
        {{end}}
        <form action="/comment" method="POST" class="comment-form">
            <input type="hidden" name="blog_id" value="{{.Blog.ID}}">
            <input type="text" name="content" placeholder="Ağa iz bırak..." required>
            <button type="submit" class="btn btn-sm">GÖNDER</button>
        </form>
    </div>
</article>
<p style="margin-top: 1rem;"><a href="/" class="btn btn-sm">GERİ DÖN</a></p>
{{end}}