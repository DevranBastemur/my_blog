{{template "base" .}}
{{define "title"}}Yazıyı Düzenle{{end}}
{{define "main"}}
<div class="admin-header">
    <h2 style="margin: 0;">Yazıyı Düzenle</h2>
    <a href="/admin" class="btn">İptal / Geri Dön</a>
</div>

<div class="admin-section">
    <form action="/admin/update" method="POST" enctype="multipart/form-data">
        <!-- Düzenlenen yazının kimliğini gizli olarak gönderiyoruz -->
        <input type="hidden" name="id" value="{{.Blog.ID}}">
        <input type="hidden" name="existing_image" value="{{.Blog.ImagePath}}">
        
        <div class="form-group">
            <label for="title">Blog Başlığı</label>
            <input type="text" id="title" name="title" value="{{.Blog.Title}}" required>
        </div>
        <div class="form-group">
            <label for="image">Görsel Yükle (Değiştirmek istersen seç)</label>
            {{if .Blog.ImagePath}}
                <div style="margin-bottom: 10px;"><img src="{{.Blog.ImagePath}}" style="max-width: 200px; border-radius: 4px; border: 1px solid var(--border);"></div>
            {{end}}
            <input type="file" id="image" name="image" accept="image/png, image/jpeg, image/webp, image/gif">
        </div>
        <div class="form-group">
            <label for="content">Yazı İçeriği</label>
            <textarea id="content" name="content" rows="10" required>{{.Blog.Content}}</textarea>
        </div>
        <button type="submit" class="btn">Değişiklikleri Kaydet</button>
    </form>
</div>
{{end}}