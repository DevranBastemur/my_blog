{{template "base" .}}
{{define "title"}}Admin Girişi{{end}}
{{define "main"}}
    <div style="max-width: 400px; margin: 0 auto; background-color: var(--bg-card); padding: 2rem; border-radius: 8px; border: 1px solid var(--border);">
        <h2 style="text-align: center; margin-top: 0;">Sistem Girişi</h2>
        {{if .Error}}
            <div style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 1rem; border-radius: 4px; margin-bottom: 1rem; border: 1px solid #ef4444;">
                {{.Error}}
            </div>
        {{end}}
        <form action="/login" method="POST">
            <div class="form-group">
                <label>Parola</label>
                <input type="password" name="password" required>
            </div>
            <button type="submit" style="width: 100%;">Giriş Yap</button>
        </form>
    </div>
{{end}}