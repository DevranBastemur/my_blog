{{define "base"}}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{block "title" .}}Sayfa Bulunamadı{{end}} - DevRyanBlog</title>
    <link rel="stylesheet" href="/static/css/main.css">
</head>
<body>
    <header>
        <div class="brand">
            <h1>
                <a href="/">
                    <img src="/static/img/logo.png" alt="DevRyanBlog Logo" class="logo-img">
                    <span>DevRyanBlog</span>
                </a>
            </h1>
        </div>
        <nav>
            <a href="/">Ana Sayfa</a>
            <a href="/admin" class="nav-admin">Admin</a>
        </nav>
    </header>

    <main>
        {{block "main" .}}<p>İçerik yüklenirken bir sorun oluştu.</p>{{end}}
    </main>

    <footer>
        <p>&copy; 2026 Devryan. Tüm hakları saklıdır.</p>
    </footer>
</body>
</html>
{{end}}